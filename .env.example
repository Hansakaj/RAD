# Copy this file to `.env` and fill in your Clerk publishable key
# Find it in the Clerk dashboard (API Keys)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Optional: POST endpoint that sends paid ticket emails.
# The app sends { to, subject, ticket, qrCode, text } to this URL after payment.
VITE_TICKET_EMAIL_ENDPOINT=https://your-api.example.com/send-ticket-email
